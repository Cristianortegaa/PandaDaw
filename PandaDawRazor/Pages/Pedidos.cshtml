@page
@model PandaDawRazor.Pages.PedidosModel
@{
    ViewData["Title"] = "Mis Pedidos";
    Layout = "_Layout";
}

<div class="bg-base-200 min-h-screen">
    <div class="max-w-4xl mx-auto p-6">
        <!-- Header -->
        <div class="mb-6">
            <h1 class="text-2xl font-bold flex items-center gap-2">
                <i class="fa-solid fa-box text-primary"></i>
                Mis Pedidos
            </h1>
            <p class="text-base-content/60 text-sm mt-1">
                Historial de todas tus compras
            </p>
        </div>

        @if (!Model.Pedidos.Any())
        {
            <!-- Sin pedidos -->
            <div class="card bg-base-100 shadow-xl">
                <div class="card-body items-center text-center py-16">
                    <i class="fa-solid fa-shopping-bag text-8xl text-base-content/20 mb-4"></i>
                    <h2 class="text-xl font-bold">No tienes pedidos</h2>
                    <p class="text-base-content/60 max-w-md">
                        Aún no has realizado ninguna compra. ¡Explora nuestro catálogo y encuentra lo que necesitas!
                    </p>
                    <a asp-page="/Index" class="btn btn-primary mt-4">
                        <i class="fa-solid fa-shopping-cart mr-2"></i>
                        Ir a comprar
                    </a>
                </div>
            </div>
        }
        else
        {
            <!-- Lista de pedidos -->
            <div class="flex flex-col gap-4">
                @foreach (var pedido in Model.Pedidos.OrderByDescending(p => p.FechaCompra))
                {
                    <div class="card bg-base-100 shadow-xl">
                        <div class="card-body">
                            <!-- Header del pedido -->
                            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 pb-3 border-b border-base-300">
                                <div class="flex items-center gap-4">
                                    <div>
                                        <p class="text-sm text-base-content/60">Pedido</p>
                                        <p class="font-bold">#@pedido.Id</p>
                                    </div>
                                    <div class="divider divider-horizontal mx-0"></div>
                                    <div>
                                        <p class="text-sm text-base-content/60">Fecha</p>
                                        <p class="font-medium">@pedido.FechaCompra.ToString("dd/MM/yyyy HH:mm")</p>
                                    </div>
                                </div>
                                <div class="flex items-center gap-3">
                                    @{
                                        var estadoClass = pedido.Estado switch
                                        {
                                            "Pendiente" => "badge-warning",
                                            "Procesando" => "badge-info",
                                            "Enviado" => "badge-primary",
                                            "Entregado" => "badge-success",
                                            "Cancelado" => "badge-error",
                                            _ => "badge-ghost"
                                        };
                                        var estadoIcon = pedido.Estado switch
                                        {
                                            "Pendiente" => "fa-clock",
                                            "Procesando" => "fa-spinner",
                                            "Enviado" => "fa-truck",
                                            "Entregado" => "fa-check-circle",
                                            "Cancelado" => "fa-times-circle",
                                            _ => "fa-question-circle"
                                        };
                                    }
                                    <span class="badge @estadoClass gap-1">
                                        <i class="fa-solid @estadoIcon text-xs"></i>
                                        @pedido.Estado
                                    </span>
                                    <span class="text-lg font-bold text-primary">
                                        @pedido.Total.ToString("C", new System.Globalization.CultureInfo("es-ES"))
                                    </span>
                                </div>
                            </div>

                            <!-- Productos del pedido -->
                            <div class="pt-3">
                                <p class="text-sm font-medium mb-2">Productos (@pedido.Lineas.Count)</p>
                                <div class="flex flex-col gap-2">
                                    @foreach (var linea in pedido.Lineas)
                                    {
                                        <div class="flex items-center gap-3 bg-base-200 rounded-lg p-2">
                                            @if (!string.IsNullOrEmpty(linea.ProductoImagen))
                                            {
                                                <img src="@linea.ProductoImagen" alt="@linea.ProductoNombre" 
                                                     class="w-12 h-12 object-cover rounded" />
                                            }
                                            else
                                            {
                                                <div class="w-12 h-12 bg-base-300 rounded flex items-center justify-center">
                                                    <i class="fa-solid fa-music text-base-content/30"></i>
                                                </div>
                                            }
                                            <div class="flex-1 min-w-0">
                                                <a asp-page="/Detalle" asp-route-id="@linea.ProductoId" 
                                                   class="font-medium hover:text-primary transition-colors truncate block">
                                                    @linea.ProductoNombre
                                                </a>
                                                <p class="text-sm text-base-content/60">
                                                    @linea.Cantidad x @linea.PrecioUnitario.ToString("C", new System.Globalization.CultureInfo("es-ES"))
                                                </p>
                                            </div>
                                            <span class="font-medium whitespace-nowrap">
                                                @((linea.Cantidad * linea.PrecioUnitario).ToString("C", new System.Globalization.CultureInfo("es-ES")))
                                            </span>
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- Resumen -->
                            <div class="flex justify-end pt-3 border-t border-base-300 mt-3">
                                <div class="text-right">
                                    <p class="text-sm text-base-content/60">
                                        Subtotal: @((pedido.Total / 1.21m).ToString("C", new System.Globalization.CultureInfo("es-ES")))
                                    </p>
                                    <p class="text-sm text-base-content/60">
                                        IVA (21%): @((pedido.Total - pedido.Total / 1.21m).ToString("C", new System.Globalization.CultureInfo("es-ES")))
                                    </p>
                                    <p class="font-bold text-lg">
                                        Total: @pedido.Total.ToString("C", new System.Globalization.CultureInfo("es-ES"))
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Resumen general -->
            <div class="card bg-base-100 shadow mt-6">
                <div class="card-body py-4">
                    <div class="stats stats-vertical sm:stats-horizontal w-full">
                        <div class="stat">
                            <div class="stat-figure text-primary">
                                <i class="fa-solid fa-receipt text-2xl"></i>
                            </div>
                            <div class="stat-title">Total pedidos</div>
                            <div class="stat-value text-primary">@Model.Pedidos.Count</div>
                        </div>
                        <div class="stat">
                            <div class="stat-figure text-secondary">
                                <i class="fa-solid fa-box text-2xl"></i>
                            </div>
                            <div class="stat-title">Productos comprados</div>
                            <div class="stat-value text-secondary">@Model.Pedidos.Sum(p => p.Lineas.Sum(l => l.Cantidad))</div>
                        </div>
                        <div class="stat">
                            <div class="stat-figure text-accent">
                                <i class="fa-solid fa-euro-sign text-2xl"></i>
                            </div>
                            <div class="stat-title">Total gastado</div>
                            <div class="stat-value text-accent text-2xl">
                                @Model.Pedidos.Sum(p => p.Total).ToString("C", new System.Globalization.CultureInfo("es-ES"))
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
