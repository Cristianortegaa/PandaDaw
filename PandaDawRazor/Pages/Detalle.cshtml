@page "{id:long}"
@model PandaDawRazor.Pages.DetalleModel
@{
    ViewData["Title"] = Model.Producto?.Nombre ?? "Producto";
    Layout = "_Layout";
    var promedio = Model.Valoraciones.Any() ? Model.Valoraciones.Average(v => v.Estrellas) : 0;
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    @if (Model.Producto == null)
    {
        <div class="card bg-white shadow-lg border-0 rounded-3xl">
            <div class="card-body items-center text-center py-20">
                <div class="w-24 h-24 rounded-3xl bg-gradient-to-br from-primary/6 to-secondary/6 flex items-center justify-center mb-5">
                    <i class="fa-solid fa-box-open text-4xl text-primary/30"></i>
                </div>
                <h2 class="text-xl font-extrabold tracking-tight">Producto no encontrado</h2>
                <p class="text-base-content/40 text-sm mt-1">El producto que buscas no existe o ha sido eliminado.</p>
                <a asp-page="/Index" class="btn btn-primary mt-6 rounded-2xl font-bold gap-2">
                    <i class="fa-solid fa-arrow-left text-xs"></i>
                    Volver al catálogo
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- Breadcrumb -->
        <div class="text-sm breadcrumbs mb-8">
            <ul class="text-base-content/45 text-xs font-medium">
                <li><a asp-page="/Index" class="hover:text-primary transition-colors">Inicio</a></li>
                <li><a asp-page="/Index" asp-route-categoria="@Model.Producto.Category" class="hover:text-primary transition-colors">@Model.Producto.Category</a></li>
                <li class="text-base-content/70 font-semibold">@Model.Producto.Nombre</li>
            </ul>
        </div>

        <!-- Producto -->
        <div class="card bg-white shadow-lg border-0 overflow-hidden rounded-3xl">
            <div class="flex flex-col lg:flex-row">
                <!-- Imagen -->
                <figure class="lg:w-1/2 bg-base-200/40 relative overflow-hidden">
                    @if (!string.IsNullOrEmpty(Model.Producto.Imagen))
                    {
                        <img src="@Model.Producto.Imagen" alt="@Model.Producto.Nombre" 
                             class="w-full h-80 lg:h-[520px] object-cover" />
                    }
                    else
                    {
                        <div class="w-full h-80 lg:h-[520px] flex items-center justify-center bg-gradient-to-br from-primary/4 to-secondary/4">
                            <i class="fa-solid fa-box text-8xl text-primary/10"></i>
                        </div>
                    }
                    <!-- Badge flotante -->
                    <span class="badge badge-primary absolute top-5 left-5 shadow-lg font-bold text-[10px] uppercase tracking-wider rounded-xl px-3.5">@Model.Producto.Category</span>
                </figure>
                
                <!-- Info -->
                <div class="lg:w-1/2 p-8 lg:p-12 flex flex-col">
                    <div class="flex items-start justify-between gap-4">
                        <div class="flex-1">
                            <h1 class="text-2xl lg:text-3xl font-extrabold text-base-content tracking-tight leading-tight">@Model.Producto.Nombre</h1>
                        </div>
                        @if (Model.EstaAutenticado)
                        {
                            <form method="post" asp-page-handler="ToggleFavorito" asp-route-productoId="@Model.Producto.Id" asp-route-favoritoId="@Model.FavoritoId">
                                <button type="submit" class="btn btn-ghost btn-circle hover:bg-error/5 transition-all">
                                    <i class="fa-@(Model.EsFavorito ? "solid" : "regular") fa-heart text-2xl @(Model.EsFavorito ? "text-error" : "text-base-content/25 hover:text-error") transition-colors"></i>
                                </button>
                            </form>
                        }
                    </div>

                    <!-- Rating -->
                    <div class="flex items-center gap-3 mt-5">
                        <div class="rating rating-sm">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <input type="radio" class="mask mask-star-2 bg-warning" disabled 
                                       @(i <= Math.Round(promedio) ? "checked" : "") />
                            }
                        </div>
                        <span class="text-xs text-base-content/45 font-medium">
                            @promedio.ToString("0.0") (@Model.Valoraciones.Count @(Model.Valoraciones.Count == 1 ? "valoración" : "valoraciones"))
                        </span>
                    </div>

                    <!-- Descripción -->
                    <p class="text-base-content/50 mt-7 flex-1 leading-relaxed text-sm">
                        @(Model.Producto.Descripcion ?? "Sin descripción disponible para este producto.")
                    </p>

                    <div class="h-px bg-base-300/25 my-6"></div>

                    <!-- Precio y compra -->
                    <div class="flex flex-col sm:flex-row items-start sm:items-end justify-between gap-5">
                        <div>
                            <span class="text-3xl lg:text-4xl font-extrabold text-primary tracking-tight">
                                @Model.Producto.Precio.ToString("C", new System.Globalization.CultureInfo("es-ES"))
                            </span>
                            @if (Model.Producto.Stock > 0)
                            {
                                <p class="text-xs text-success font-bold flex items-center gap-1.5 mt-2.5 uppercase tracking-wider">
                                    <i class="fa-solid fa-circle text-[5px]"></i>
                                    En stock (@Model.Producto.Stock disponibles)
                                </p>
                            }
                            else
                            {
                                <p class="text-xs text-error font-bold flex items-center gap-1.5 mt-2.5 uppercase tracking-wider">
                                    <i class="fa-solid fa-circle text-[5px]"></i>
                                    Agotado
                                </p>
                            }
                        </div>
                        
                        @if (Model.Producto.Stock > 0)
                        {
                            <form method="post" asp-page-handler="AddToCart" asp-route-productoId="@Model.Producto.Id">
                                <button type="submit" class="btn btn-primary btn-lg rounded-2xl font-bold gap-2 shadow-lg">
                                    <i class="fa-solid fa-cart-plus"></i>
                                    Añadir al carrito
                                </button>
                            </form>
                        }
                        else
                        {
                            <button class="btn btn-lg rounded-2xl" disabled>
                                <i class="fa-solid fa-cart-plus mr-2"></i>
                                No disponible
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Valoraciones -->
        <div class="mt-14">
            <div class="flex items-center gap-2 mb-8">
                <span class="w-8 h-0.5 bg-warning rounded-full"></span>
                <h2 class="text-xl font-extrabold tracking-tight">Valoraciones</h2>
                <span class="text-sm text-base-content/40 font-medium">(@Model.Valoraciones.Count)</span>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-7">
                <!-- Formulario -->
                @if (Model.EstaAutenticado)
                {
                    <div class="card bg-white shadow-md border-0 rounded-3xl">
                        <div class="card-body p-7">
                            <h3 class="font-bold text-sm mb-5">Deja tu valoración</h3>
                            <form method="post" asp-page-handler="AddValoracion" asp-route-productoId="@Model.Producto.Id">
                                <div class="form-control mb-5">
                                    <label class="label">
                                        <span class="label-text font-semibold text-xs uppercase tracking-wider text-base-content/60">Puntuación</span>
                                    </label>
                                    <div class="rating rating-lg">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <input type="radio" name="Estrellas" value="@i" 
                                                   class="mask mask-star-2 bg-warning" @(i == 5 ? "checked" : "") />
                                        }
                                    </div>
                                </div>
                                <div class="form-control mb-5">
                                    <label class="label">
                                        <span class="label-text font-semibold text-xs uppercase tracking-wider text-base-content/60">Tu opinión</span>
                                    </label>
                                    <textarea name="Resena" class="textarea textarea-bordered h-28 focus:textarea-primary rounded-2xl text-sm" 
                                              placeholder="¿Qué te ha parecido este producto?" required></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary w-full rounded-2xl font-bold text-sm gap-2">
                                    <i class="fa-solid fa-paper-plane text-xs"></i>
                                    Enviar valoración
                                </button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card bg-white shadow-md border-0 rounded-3xl">
                        <div class="card-body items-center text-center py-12">
                            <div class="w-16 h-16 rounded-3xl bg-gradient-to-br from-primary/6 to-secondary/6 flex items-center justify-center mb-4">
                                <i class="fa-solid fa-user-lock text-2xl text-primary/30"></i>
                            </div>
                            <p class="text-base-content/40 text-sm font-medium">Inicia sesión para valorar</p>
                            <a asp-page="/Login" class="btn btn-primary btn-sm mt-4 rounded-2xl font-bold text-xs gap-1.5">
                                <i class="fa-solid fa-right-to-bracket text-[10px]"></i>
                                Iniciar sesión
                            </a>
                        </div>
                    </div>
                }

                <!-- Lista -->
                <div class="lg:col-span-2 flex flex-col gap-4">
                    @if (!Model.Valoraciones.Any())
                    {
                        <div class="card bg-white shadow-sm border-0 rounded-3xl">
                            <div class="card-body items-center text-center py-14">
                                <div class="w-16 h-16 rounded-3xl bg-warning/8 flex items-center justify-center mb-4">
                                    <i class="fa-regular fa-star text-2xl text-warning/40"></i>
                                </div>
                                <p class="font-bold text-sm">Sin valoraciones todavía</p>
                                <p class="text-xs text-base-content/40 mt-1">¡Sé el primero en valorar este producto!</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        @foreach (var valoracion in Model.Valoraciones.OrderByDescending(v => v.Fecha))
                        {
                            <div class="card bg-white shadow-sm border-0 rounded-2xl hover:shadow-md">
                                <div class="card-body py-5 px-6">
                                    <div class="flex items-start justify-between gap-4">
                                        <div class="flex items-center gap-3">
                                            <div class="avatar">
                                                <div class="w-10 h-10 rounded-xl ring-2 ring-primary/15 ring-offset-base-100 ring-offset-1">
                                                    <img src="https://api.dicebear.com/7.x/initials/svg?seed=@(valoracion.UsuarioNombre ?? "U")" alt="Avatar" />
                                                </div>
                                            </div>
                                            <div>
                                                <p class="font-bold text-sm text-base-content">@(valoracion.UsuarioNombre ?? "Usuario")</p>
                                                <p class="text-[11px] text-base-content/40 font-medium">@valoracion.Fecha.ToString("dd MMM yyyy")</p>
                                            </div>
                                        </div>
                                        <div class="rating rating-sm">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <input type="radio" class="mask mask-star-2 bg-warning" disabled 
                                                       @(i <= valoracion.Estrellas ? "checked" : "") />
                                            }
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(valoracion.Resena))
                                    {
                                        <p class="text-base-content/55 mt-3 text-sm leading-relaxed">@valoracion.Resena</p>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    }
</div>
