@page "{id:long}"
@model PandaDawRazor.Pages.DetalleModel
@{
    ViewData["Title"] = Model.Producto?.Nombre ?? "Producto";
    Layout = "_Layout";
    var promedio = Model.Valoraciones.Any() ? Model.Valoraciones.Average(v => v.Estrellas) : 0;
}

<div class="max-w-7xl mx-auto px-4 py-8">
    @if (Model.Producto == null)
    {
        <div class="card bg-base-100 shadow-md border border-base-300">
            <div class="card-body items-center text-center py-16">
                <div class="w-20 h-20 rounded-full bg-base-200 flex items-center justify-center mb-4">
                    <i class="fa-solid fa-box-open text-4xl text-base-content/30"></i>
                </div>
                <h2 class="text-xl font-bold">Producto no encontrado</h2>
                <p class="text-base-content/60">El producto que buscas no existe o ha sido eliminado.</p>
                <a asp-page="/Index" class="btn btn-primary mt-4">
                    <i class="fa-solid fa-arrow-left mr-2"></i>
                    Volver al catálogo
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- Breadcrumb -->
        <div class="text-sm breadcrumbs mb-6">
            <ul class="text-base-content/60">
                <li><a asp-page="/Index" class="hover:text-primary">Inicio</a></li>
                <li><a asp-page="/Index" asp-route-categoria="@Model.Producto.Category" class="hover:text-primary">@Model.Producto.Category</a></li>
                <li class="text-base-content font-medium">@Model.Producto.Nombre</li>
            </ul>
        </div>

        <!-- Producto -->
        <div class="card bg-base-100 shadow-md border border-base-300 overflow-hidden">
            <div class="flex flex-col lg:flex-row">
                <!-- Imagen -->
                <figure class="lg:w-1/2 bg-base-200">
                    @if (!string.IsNullOrEmpty(Model.Producto.Imagen))
                    {
                        <img src="@Model.Producto.Imagen" alt="@Model.Producto.Nombre" 
                             class="w-full h-80 lg:h-[500px] object-cover" />
                    }
                    else
                    {
                        <div class="w-full h-80 lg:h-[500px] flex items-center justify-center bg-gradient-to-br from-primary/10 to-secondary/10">
                            <i class="fa-solid fa-music text-8xl text-primary/20"></i>
                        </div>
                    }
                </figure>
                
                <!-- Info -->
                <div class="lg:w-1/2 p-6 lg:p-8 flex flex-col">
                    <div class="flex items-start justify-between gap-4">
                        <div class="flex-1">
                            <span class="badge badge-primary mb-3">@Model.Producto.Category</span>
                            <h1 class="text-2xl lg:text-3xl font-bold text-base-content">@Model.Producto.Nombre</h1>
                        </div>
                        @if (Model.EstaAutenticado)
                        {
                            <form method="post" asp-page-handler="ToggleFavorito" asp-route-productoId="@Model.Producto.Id" asp-route-favoritoId="@Model.FavoritoId">
                                <button type="submit" class="btn btn-ghost btn-circle">
                                    <i class="fa-@(Model.EsFavorito ? "solid" : "regular") fa-heart text-2xl @(Model.EsFavorito ? "text-error" : "text-base-content/40 hover:text-error")"></i>
                                </button>
                            </form>
                        }
                    </div>

                    <!-- Rating -->
                    <div class="flex items-center gap-3 mt-4">
                        <div class="rating rating-sm">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <input type="radio" class="mask mask-star-2 bg-warning" disabled 
                                       @(i <= Math.Round(promedio) ? "checked" : "") />
                            }
                        </div>
                        <span class="text-sm text-base-content/60">
                            @promedio.ToString("0.0") (@Model.Valoraciones.Count @(Model.Valoraciones.Count == 1 ? "valoración" : "valoraciones"))
                        </span>
                    </div>

                    <!-- Descripción -->
                    <p class="text-base-content/70 mt-6 flex-1">
                        @(Model.Producto.Descripcion ?? "Sin descripción disponible para este producto.")
                    </p>

                    <div class="divider"></div>

                    <!-- Precio y compra -->
                    <div class="flex flex-col sm:flex-row items-start sm:items-end justify-between gap-4">
                        <div>
                            <span class="text-3xl lg:text-4xl font-bold text-primary">
                                @Model.Producto.Precio.ToString("C", new System.Globalization.CultureInfo("es-ES"))
                            </span>
                            @if (Model.Producto.Stock > 0)
                            {
                                <p class="text-sm text-success flex items-center gap-2 mt-2">
                                    <i class="fa-solid fa-check-circle"></i>
                                    En stock (@Model.Producto.Stock disponibles)
                                </p>
                            }
                            else
                            {
                                <p class="text-sm text-error flex items-center gap-2 mt-2">
                                    <i class="fa-solid fa-times-circle"></i>
                                    Agotado
                                </p>
                            }
                        </div>
                        
                        @if (Model.Producto.Stock > 0)
                        {
                            <form method="post" asp-page-handler="AddToCart" asp-route-productoId="@Model.Producto.Id">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fa-solid fa-cart-plus mr-2"></i>
                                    Añadir al carrito
                                </button>
                            </form>
                        }
                        else
                        {
                            <button class="btn btn-lg" disabled>
                                <i class="fa-solid fa-cart-plus mr-2"></i>
                                No disponible
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Valoraciones -->
        <div class="mt-8">
            <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
                <i class="fa-solid fa-star text-warning"></i>
                Valoraciones (@Model.Valoraciones.Count)
            </h2>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- Formulario de valoración -->
                @if (Model.EstaAutenticado)
                {
                    <div class="card bg-base-100 shadow-md border border-base-300">
                        <div class="card-body">
                            <h3 class="font-bold mb-4">Deja tu valoración</h3>
                            <form method="post" asp-page-handler="AddValoracion" asp-route-productoId="@Model.Producto.Id">
                                <div class="form-control mb-4">
                                    <label class="label">
                                        <span class="label-text font-medium">Puntuación</span>
                                    </label>
                                    <div class="rating rating-lg">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <input type="radio" name="Estrellas" value="@i" 
                                                   class="mask mask-star-2 bg-warning" @(i == 5 ? "checked" : "") />
                                        }
                                    </div>
                                </div>
                                <div class="form-control mb-4">
                                    <label class="label">
                                        <span class="label-text font-medium">Tu opinión</span>
                                    </label>
                                    <textarea name="Resena" class="textarea textarea-bordered h-28 focus:textarea-primary" 
                                              placeholder="¿Qué te ha parecido este producto?" required></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary w-full">
                                    <i class="fa-solid fa-paper-plane mr-2"></i>
                                    Enviar valoración
                                </button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card bg-base-100 shadow-md border border-base-300">
                        <div class="card-body items-center text-center py-10">
                            <div class="w-14 h-14 rounded-full bg-base-200 flex items-center justify-center mb-3">
                                <i class="fa-solid fa-user-lock text-2xl text-base-content/30"></i>
                            </div>
                            <p class="text-base-content/60">Inicia sesión para valorar</p>
                            <a asp-page="/Login" class="btn btn-primary btn-sm mt-3">
                                <i class="fa-solid fa-right-to-bracket mr-2"></i>
                                Iniciar sesión
                            </a>
                        </div>
                    </div>
                }

                <!-- Lista de valoraciones -->
                <div class="lg:col-span-2 flex flex-col gap-4">
                    @if (!Model.Valoraciones.Any())
                    {
                        <div class="card bg-base-100 shadow-md border border-base-300">
                            <div class="card-body items-center text-center py-10">
                                <div class="w-14 h-14 rounded-full bg-base-200 flex items-center justify-center mb-3">
                                    <i class="fa-regular fa-star text-2xl text-base-content/30"></i>
                                </div>
                                <p class="font-medium">Sin valoraciones todavía</p>
                                <p class="text-sm text-base-content/50">¡Sé el primero en valorar este producto!</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        @foreach (var valoracion in Model.Valoraciones.OrderByDescending(v => v.Fecha))
                        {
                            <div class="card bg-base-100 shadow-sm border border-base-300">
                                <div class="card-body py-4">
                                    <div class="flex items-start justify-between gap-4">
                                        <div class="flex items-center gap-3">
                                            <div class="avatar">
                                                <div class="w-10 h-10 rounded-full ring ring-primary ring-offset-base-100 ring-offset-1">
                                                    <img src="https://api.dicebear.com/7.x/initials/svg?seed=@(valoracion.UsuarioNombre ?? "U")" alt="Avatar" />
                                                </div>
                                            </div>
                                            <div>
                                                <p class="font-medium text-base-content">@(valoracion.UsuarioNombre ?? "Usuario")</p>
                                                <p class="text-xs text-base-content/50">@valoracion.Fecha.ToString("dd MMM yyyy")</p>
                                            </div>
                                        </div>
                                        <div class="rating rating-sm">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <input type="radio" class="mask mask-star-2 bg-warning" disabled 
                                                       @(i <= valoracion.Estrellas ? "checked" : "") />
                                            }
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(valoracion.Resena))
                                    {
                                        <p class="text-base-content/70 mt-3">@valoracion.Resena</p>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    }
</div>
