@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="min-h-[calc(100vh-200px)] flex items-center justify-center p-6">
    <div class="card bg-white shadow-xl border border-base-300/50 rounded-2xl max-w-lg w-full">
        <div class="card-body items-center text-center gap-4 p-8">
            <div class="w-16 h-16 rounded-2xl bg-error/10 flex items-center justify-center">
                <i class="fa-solid fa-triangle-exclamation text-3xl text-error"></i>
            </div>
            <h1 class="text-2xl font-extrabold text-base-content tracking-tight">Ha ocurrido un error</h1>
            <p class="text-base-content/50 text-sm">Se ha producido un error al procesar tu solicitud.</p>

            @if (Model.ShowRequestId)
            {
                <div class="bg-base-200/60 rounded-xl px-4 py-3 w-full">
                    <p class="text-xs text-base-content/50">Request ID</p>
                    <p class="font-mono text-sm text-base-content/70">@Model.RequestId</p>
                </div>
            }

            <a asp-page="/Index" class="btn btn-primary rounded-xl font-semibold mt-2">
                <i class="fa-solid fa-home mr-2"></i>
                Volver al inicio
            </a>
        </div>
    </div>
</div>